# =============================================================
# 5MIN Backend - Environment Variables
# 이 파일을 복사해서 .env 로 만들고 실제 값을 채우세요.
# cp .env.example .env
# =============================================================

# ── Database (AWS RDS MySQL) ──────────────────────────────────
# 형식: mysql://유저:비밀번호@RDS엔드포인트:3306/DB이름
DATABASE_URL="mysql://admin:yourpassword@your-rds-endpoint.ap-northeast-2.rds.amazonaws.com:3306/fivemin"

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development   # development | production

# ── CORS ─────────────────────────────────────────────────────
# 허용할 클라이언트 Origin (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# ── Admin ─────────────────────────────────────────────────────
# 백오피스 전용 API 키 (X-Admin-Key 헤더로 전달)
# 알럿 등록·장비 상태 변경·실시간 병상 수동 입력에 사용
ADMIN_API_KEY=your-strong-admin-api-key-here
